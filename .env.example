# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/jw-marriage-advisory?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=change_this_too

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=jw-marriage-advisory

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Marriage Advisory Platform
EMAIL_FROM_ADDRESS=no-reply@example.org

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=change_this_too

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Uploads
MAX_UPLOAD_SIZE_MB=5

# Super Admin seed (used by utils/seedSuperAdmin.js)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.org
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Session
SESSION_TIMEOUT_MINUTES=60
